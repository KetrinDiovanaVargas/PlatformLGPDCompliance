# Production Environment Variables
# Used for production builds (npm run build)
# API keys should be configured in Vercel Dashboard, not here

# API Backend URL - must match CORS allowedOrigins in server/server.mjs
VITE_API_BASE_URL=https://platformlgpdcompliance.com.br

# Note: API keys (ANTHROPIC_API_KEY, DEEPSEEK_API_KEY) must be set in Vercel Environment Variables
# Do NOT commit secrets to git - configure them in Vercel Dashboard
