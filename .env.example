# ========================================================================
# FIREBASE CONFIGURATION (Required)
# ========================================================================
# Get these from Firebase Console → Project Settings

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Firebase Admin SDK (Backend)
# Option 1: Full service account JSON (base64 encoded for CI/CD)
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=eyJwcm9qZWN0X2lkIjoiLi4uIn0=

# Option 2: Individual credentials
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# ========================================================================
# AI PROVIDERS
# ========================================================================

# Groq API (Primary)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Anthropic Claude (Fallback)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ========================================================================
# SERVER CONFIGURATION
# ========================================================================

PORT=8787
NODE_ENV=development

# Backend URL (for redirects, emails, etc)
BACKEND_URL=http://localhost:8787

# ========================================================================
# SECURITY
# ========================================================================

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window

# Session timeout (minutes)
SESSION_TIMEOUT=30

# ========================================================================
# LOGGING
# ========================================================================

LOG_LEVEL=info
# Options: error, warn, info, debug, trace

# ========================================================================
# DEPLOYMENT
# ========================================================================

# Vercel deployment URL (if applicable)
VITE_API_BASE_URL=https://api.example.com

# ========================================================================
# DEVELOPMENT ONLY
# ========================================================================

# Skip auth for local development (NEVER use in production!)
# SKIP_AUTH=false
