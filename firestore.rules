rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ====================================================================
    // ASSESSMENTS COLLECTION - Public Access
    // ====================================================================

    match /assessments/{assessmentId} {
      // Anyone can read assessments
      allow read: if true;

      // Authenticated users can create
      allow create: if request.auth != null;

      // Owners can update
      allow update: if request.auth != null &&
                       resource.data.ownerId == request.auth.uid;

      // Owners can delete
      allow delete: if request.auth != null &&
                       resource.data.ownerId == request.auth.uid;

      // ====================================================================
      // ASSESSMENT_SESSIONS SUBCOLLECTION
      // ====================================================================

      match /assessment_sessions/{sessionId} {
        // Anyone can read (for public surveys)
        allow read: if true;

        // Anyone can create sessions
        allow create: if true;

        // Anyone can update their own session
        allow update: if true;

        // Anyone can delete
        allow delete: if true;

        // ====================================================================
        // STAGES SUBCOLLECTION
        // ====================================================================

        match /stages/{stageNumber} {
          allow read, write: if true;
        }

        // ====================================================================
        // FINAL_REPORT SUBCOLLECTION
        // ====================================================================

        match /final_report/{reportId} {
          allow read, write: if true;
        }
      }
    }

    // ====================================================================
    // DEFAULT - Allow all for development
    // ====================================================================

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
