rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ====================================================================
    // ASSESSMENTS COLLECTION - Public Access
    // ====================================================================

    match /assessments/{assessmentId} {
      // Anyone can read assessments
      allow read: if true;

      // Authenticated users can create
      allow create: if request.auth != null;

      // Owners can update
      allow update: if request.auth != null &&
                       resource.data.ownerId == request.auth.uid;

      // Owners can delete
      allow delete: if request.auth != null &&
                       resource.data.ownerId == request.auth.uid;

      // ====================================================================
      // ASSESSMENT_SESSIONS SUBCOLLECTION
      // ====================================================================

      match /assessment_sessions/{sessionId} {
        // Anyone can read (for public surveys)
        allow read: if true;

        // Anyone can create sessions
        allow create: if true;

        // Anyone can update their own session
        allow update: if true;

        // Anyone can delete
        allow delete: if true;

        // ====================================================================
        // STAGES SUBCOLLECTION
        // ====================================================================

        match /stages/{stageNumber} {
          allow read, write: if true;
        }

        // ====================================================================
        // FINAL_REPORT SUBCOLLECTION
        // ====================================================================

        match /final_report/{reportId} {
          allow read, write: if true;
        }
      }
    }

    // ====================================================================
    // FEEDBACK COLLECTION - Post-Assessment Survey Responses
    // ====================================================================
    // Collects user satisfaction and usability feedback after assessment completion
    // One feedback per session (identified by sessionId)

    match /feedback/{feedbackId} {
      // Anyone can submit feedback (public survey system)
      // Validation: sessionId must be non-empty string
      allow create: if request.resource.data.sessionId is string &&
                       request.resource.data.sessionId.size() > 0 &&
                       request.resource.data.assessmentId is string &&
                       request.resource.data.responses is list &&
                       request.resource.data.timestamp != null;

      // Only authenticated admins can read all feedback
      allow read: if request.auth != null &&
                     request.auth.token.admin == true;

      // Only authenticated admins can update feedback
      allow update: if request.auth != null &&
                       request.auth.token.admin == true;

      // Only authenticated admins can delete feedback
      allow delete: if request.auth != null &&
                       request.auth.token.admin == true;
    }

    // ====================================================================
    // RESPONSES COLLECTION - Questionnaire Responses
    // ====================================================================

    match /responses/{responseId} {
      allow read, write: if true;
    }

    // ====================================================================
    // RESPOSTAS COLLECTION - Brazilian Portuguese Responses
    // ====================================================================

    match /respostas/{respostaId} {
      allow read, write: if true;
    }

    // ====================================================================
    // DEFAULT - Allow all for development
    // ⚠️ NOTE: In production, replace with explicit deny:
    //    match /{document=**} {
    //      allow read, write: if false;
    //    }
    // ====================================================================

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
