rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ====================================================================
    // HELPER FUNCTIONS
    // ====================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin(uid) {
      return exists(/databases/{database}/documents/admins/{uid}) &&
             get(/databases/{database}/documents/admins/{uid}).data.active == true;
    }

    function isMaster(uid) {
      return isAdmin(uid) &&
             get(/databases/{database}/documents/admins/{uid}).data.role == "MASTER";
    }

    function isAssessmentOwner(uid, assessmentId) {
      return exists(/databases/{database}/documents/assessments/{assessmentId}) &&
             get(/databases/{database}/documents/assessments/{assessmentId}).data.ownerId == uid;
    }

    function isActiveAssessment(assessmentId) {
      return exists(/databases/{database}/documents/assessments/{assessmentId}) &&
             get(/databases/{database}/documents/assessments/{assessmentId}).data.active == true &&
             get(/databases/{database}/documents/assessments/{assessmentId}).data.deleted != true;
    }

    // ====================================================================
    // ASSESSMENTS COLLECTION
    // ====================================================================

    match /assessments/{assessmentId} {
      // Authenticated admins can read all assessments
      allow read: if isAuthenticated() && isAdmin(request.auth.uid);

      // Public read: anyone can read active assessments (for public surveys)
      allow read: if isActiveAssessment(assessmentId);

      // Only authenticated admins can create assessments
      allow create: if isAuthenticated() && isAdmin(request.auth.uid) &&
                       request.resource.data.ownerId == request.auth.uid &&
                       request.resource.data.active == true &&
                       request.resource.data.deleted == false;

      // Admins can update their own assessments, Masters can update any
      allow update: if isAuthenticated() && isAdmin(request.auth.uid) &&
                       (isMaster(request.auth.uid) ||
                        isAssessmentOwner(request.auth.uid, assessmentId));

      // Only Masters can delete assessments
      allow delete: if isAuthenticated() && isMaster(request.auth.uid);

      // ====================================================================
      // ASSESSMENT_SESSIONS SUBCOLLECTION
      // ====================================================================

      match /assessment_sessions/{sessionId} {
        // Users can create their own session (authenticated or anonymous)
        allow create: if (isAuthenticated() &&
                         request.resource.data.userId == request.auth.uid) ||
                       (!isAuthenticated() &&
                         request.resource.data.userId != null &&
                         request.resource.data.assessmentId == assessmentId);

        // Users can read/update their own sessions
        allow read, update: if (isAuthenticated() &&
                                resource.data.userId == request.auth.uid) ||
                             (!isAuthenticated() &&
                              resource.data.userId == request.auth.token.uid);

        // Admins can read/delete sessions for their assessments
        allow read: if isAuthenticated() && isAdmin(request.auth.uid) &&
                       exists(/databases/{database}/documents/assessments/{parent()}/assessment_sessions/{sessionId}) &&
                       (isMaster(request.auth.uid) ||
                        isAssessmentOwner(request.auth.uid, resource.data.assessmentId));

        allow delete: if isAuthenticated() && isAdmin(request.auth.uid) &&
                        (isMaster(request.auth.uid) ||
                         isAssessmentOwner(request.auth.uid, resource.data.assessmentId));

        // ====================================================================
        // STAGES SUBCOLLECTION
        // ====================================================================

        match /stages/{stageNumber} {
          // Users can create/read/update their own session stages
          allow create, read, update: if (isAuthenticated() &&
                                           parent().data.userId == request.auth.uid) ||
                                         (!isAuthenticated() &&
                                          parent().data.userId == request.auth.token.uid);

          // Validate stage data
          allow create: if request.resource.data.keys().hasAll(['stageId', 'responses', 'completedAt']);
        }

        // ====================================================================
        // FINAL_REPORT SUBCOLLECTION
        // ====================================================================

        match /final_report/{reportId} {
          // Users can read their own session reports
          allow read: if (isAuthenticated() &&
                         parent().data.userId == request.auth.uid) ||
                       (!isAuthenticated() &&
                        parent().data.userId == request.auth.token.uid);

          // Admins can read reports for their assessments
          allow read: if isAuthenticated() && isAdmin(request.auth.uid) &&
                        (isMaster(request.auth.uid) ||
                         isAssessmentOwner(request.auth.uid, parent().data.assessmentId));

          // Only backend/server can write reports (via Cloud Functions)
          allow write: if false;
        }
      }
    }

    // ====================================================================
    // ADMINS COLLECTION (Admin Management)
    // ====================================================================

    match /admins/{uid} {
      // Users can read their own admin profile
      allow read: if isAuthenticated() && uid == request.auth.uid;

      // Only MASTER admins can read other admin profiles
      allow read: if isAuthenticated() && isMaster(request.auth.uid);

      // Only MASTER admins can create new admin users
      allow create: if isAuthenticated() && isMaster(request.auth.uid) &&
                       request.resource.data.createdBy == request.auth.uid &&
                       request.resource.data.active == true &&
                       request.resource.data.role in ['ADMIN', 'MASTER'];

      // Only MASTER admins can update admin users
      allow update: if isAuthenticated() && isMaster(request.auth.uid) &&
                       request.resource.data.role in ['ADMIN', 'MASTER'];

      // Only MASTER admins can delete admin users
      allow delete: if isAuthenticated() && isMaster(request.auth.uid);
    }

    // ====================================================================
    // ADMIN_SESSIONS COLLECTION (Session Tracking)
    // ====================================================================

    match /admin_sessions/{sessionId} {
      // Admins can view their own sessions
      allow read: if isAuthenticated() &&
                     (resource.data.uid == request.auth.uid ||
                      isMaster(request.auth.uid));

      // Only authenticated admins can create sessions
      allow create, update: if isAuthenticated() && isAdmin(request.auth.uid) &&
                               request.resource.data.uid == request.auth.uid;
    }

    // ====================================================================
    // CONSOLIDATED_ANALYSIS COLLECTION
    // ====================================================================

    match /consolidated_analysis/{analysisId} {
      // Admins can read analysis for their assessments
      allow read: if isAuthenticated() && isAdmin(request.auth.uid);

      // Only backend/server can write analysis (via Cloud Functions)
      allow write: if false;
    }

    // ====================================================================
    // AUDIT_LOGS COLLECTION (Optional but Recommended for LGPD)
    // ====================================================================

    match /audit_logs/{logId} {
      // Admins can read audit logs for their data
      allow read: if isAuthenticated() && isAdmin(request.auth.uid);

      // Only backend/server can write logs
      allow write: if false;
    }

    // ====================================================================
    // DEFAULT DENY
    // ====================================================================

    // Explicitly deny access to all other collections/documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
